# LLM Generation & Analysis
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_GENERATION=claude-3-5-sonnet-20241022
CLAUDE_MODEL_ANALYSIS=claude-3-haiku-20240307

# Embeddings (provider: "local" or "openai")
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
# OPENAI_API_KEY=sk-...  # only needed if EMBEDDING_PROVIDER=openai

# Storage and Settings
CHROMA_PERSIST_DIR=./chroma_data
KARATE_PROJECT_PATH=./karate_project
LOG_LEVEL=INFO
