{
  "request": {
    "method": "POST",
    "url": "/api/v1/orders",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer test-token"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.customerId == '  cust-123')]"
      },
      {
        "matchesJsonPath": "$.[?(@.customerTier == 'STANDARD')]"
      }
    ]
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "ord-13",
      "customerId": "  cust-123",
      "customerTier": "STANDARD",
      "status": "PENDING",
      "discountApplied": 0.0,
      "totalAmount": 340.0
    }
  }
}