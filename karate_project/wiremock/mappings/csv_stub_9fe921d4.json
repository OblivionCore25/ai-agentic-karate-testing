{
  "request": {
    "method": "POST",
    "url": "/api/v1/orders",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer test-token"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.customerId == 'cust-200')]"
      },
      {
        "matchesJsonPath": "$.[?(@.customerTier == 'STANDARD')]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.productId == 'prod-1')]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.quantity == 1)]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.price == 100.0)]"
      }
    ]
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "ord-49",
      "customerId": "cust-200",
      "customerTier": "STANDARD",
      "status": "PENDING",
      "discountApplied": 0.0,
      "totalAmount": 0.0
    }
  }
}