{
  "request": {
    "method": "POST",
    "url": "/api/v1/orders",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer test-token"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.customerId == 'cust-gold-multi-4')]"
      },
      {
        "matchesJsonPath": "$.[?(@.customerTier == 'GOLD')]"
      }
    ]
  },
  "response": {
    "status": 201,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "id": "ord-61",
      "customerId": "cust-gold-multi-4",
      "customerTier": "GOLD",
      "status": "PENDING",
      "discountApplied": 25.0,
      "totalAmount": 225.0
    }
  }
}