{
  "request": {
    "method": "POST",
    "url": "/api/v1/orders",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer test-token"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.[?(@.customerId == 'cust-126')]"
      },
      {
        "matchesJsonPath": "$.[?(@.customerTier == 'PREMIUM')]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.productId == 'prod-3')]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.quantity == 3)]"
      },
      {
        "matchesJsonPath": "$.items[0].[?(@.price == 200.0)]"
      }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": "Validation Error or Bad Request"
    }
  }
}